<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <h2 class="section-heading">Login anomalies</h2>
          <div class="table-wrap table-block">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Login time</th>
                  <th>Source IP</th>
                  <th>Device</th>
                  <th>Anomalous</th>
                </tr>
              </thead>
              <tbody>
                {{#each loginEvents}}
                  <tr>
                    <td>{{this.user.name}}</td>
                    <td>{{this.loginTime}}</td>
                    <td>{{this.sourceIp}}</td>
                    <td>{{this.deviceLabel}}</td>
                    <td>{{this.anomalyFlag}}</td>
                  </tr>
                {{else}}
                  <tr>
                    <td class="empty-cell" colspan="5">No login events are available for the selected audit window.</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>

          <h2 class="section-heading table-block">Host events</h2>
          <div class="table-wrap table-block">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Host</th>
                  <th>Event type</th>
                  <th>Severity</th>
                  <th>Summary</th>
                </tr>
              </thead>
              <tbody>
                {{#each systemEvents}}
                  <tr>
                    <td>{{this.hostname}}</td>
                    <td>{{this.eventType}}</td>
                    <td>{{this.severity}}</td>
                    <td>{{this.summary}}</td>
                  </tr>
                {{else}}
                  <tr>
                    <td class="empty-cell" colspan="4">No host events are available.</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>

          <h2 class="section-heading table-block">Network activity</h2>
          <div class="table-wrap table-block">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Host</th>
                  <th>Destination</th>
                  <th>Port</th>
                  <th>Protocol</th>
                  <th>Risk</th>
                </tr>
              </thead>
              <tbody>
                {{#each networkEvents}}
                  <tr>
                    <td>{{this.hostname}}</td>
                    <td>{{this.destination}}</td>
                    <td>{{this.port}}</td>
                    <td>{{this.protocol}}</td>
                    <td>{{this.riskLabel}}</td>
                  </tr>
                {{else}}
                  <tr>
                    <td class="empty-cell" colspan="5">No network events are available.</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
