{
  "name": "sankofa-payroll-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Internal payroll and compliance demo platform for Sankofa Payroll & Compliance Services.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:push && npm run db:seed",
    "test": "jest --config ./test/jest-e2e.json",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "connect-sqlite3": "^0.9.16",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@types/connect-sqlite3": "^0.9.6",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.5",
    "prisma": "^6.6.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
