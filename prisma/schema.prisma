generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PAYROLL_ADMIN
  COMPLIANCE_OFFICER
  AUDIT_ANALYST
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole
  department   String
  status       String
  lastLogin    DateTime?
  createdBatches PayrollBatch[]
  complianceReviews ComplianceReview[]
  loginEvents  LoginEvent[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Employee {
  id                  Int      @id @default(autoincrement())
  employeeCode        String   @unique
  fullName            String
  department          String
  jobTitle            String
  payGrade            String
  taxIdentifier       String
  bankName            String
  maskedAccountNumber String
  employmentStatus    String
  payrollEntries      PayrollEntry[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PayrollBatch {
  id         Int            @id @default(autoincrement())
  batchCode  String         @unique
  quarter    String
  year       Int
  status     String
  submittedAt DateTime?
  totalGross Float
  totalNet   Float
  createdById Int
  createdBy  User           @relation(fields: [createdById], references: [id])
  entries    PayrollEntry[]
  complianceReview ComplianceReview?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model PayrollEntry {
  id          Int          @id @default(autoincrement())
  batchId     Int
  employeeId  Int
  baseSalary  Float
  allowances  Float
  deductions  Float
  tax         Float
  netPay      Float
  notes       String?
  isFlagged   Boolean      @default(false)
  batch       PayrollBatch @relation(fields: [batchId], references: [id])
  employee    Employee     @relation(fields: [employeeId], references: [id])
  complianceFlags ComplianceFlag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([batchId, employeeId])
}

model ComplianceReview {
  id              Int              @id @default(autoincrement())
  batchId         Int              @unique
  reviewerId      Int
  reviewStatus    String
  comments        String?
  completedChecks Int
  approvedAt      DateTime?
  batch           PayrollBatch     @relation(fields: [batchId], references: [id])
  reviewer        User             @relation(fields: [reviewerId], references: [id])
  flags           ComplianceFlag[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ComplianceFlag {
  id              Int              @id @default(autoincrement())
  reviewId        Int
  payrollEntryId  Int
  severity        String
  ruleType        String
  description     String
  resolutionState String
  review          ComplianceReview @relation(fields: [reviewId], references: [id])
  payrollEntry     PayrollEntry    @relation(fields: [payrollEntryId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model LoginEvent {
  id          Int      @id @default(autoincrement())
  userId      Int
  loginTime   DateTime
  sourceIp    String
  deviceLabel String
  anomalyFlag Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemEvent {
  id        Int      @id @default(autoincrement())
  hostname  String
  eventType String
  timestamp DateTime
  severity  String
  summary   String
  details   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NetworkEvent {
  id        Int      @id @default(autoincrement())
  hostname  String
  destination String
  port      Int
  protocol  String
  timestamp DateTime
  riskLabel String
  notes     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
