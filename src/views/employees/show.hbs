<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <div class="detail-grid">
            <article class="detail-card">
              <span class="detail-kicker">Identity</span>
              <h2>{{employee.fullName}}</h2>
              <div class="detail-stack">
                <div><strong>Employee code</strong><span>{{employee.employeeCode}}</span></div>
                <div><strong>Department</strong><span>{{employee.department}}</span></div>
                <div><strong>Job title</strong><span>{{employee.jobTitle}}</span></div>
                <div><strong>Employment status</strong><span>{{employee.employmentStatus}}</span></div>
              </div>
            </article>

            <article class="detail-card">
              <span class="detail-kicker">Payroll Profile</span>
              <h2>Compensation context</h2>
              <div class="detail-stack">
                <div><strong>Pay grade</strong><span>{{employee.payGrade}}</span></div>
                <div><strong>Tax identifier</strong><span>{{employee.taxIdentifier}}</span></div>
                <div><strong>Bank name</strong><span>{{employee.bankName}}</span></div>
                <div><strong>Masked account</strong><span>{{employee.maskedAccountNumber}}</span></div>
              </div>
            </article>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
