<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <div class="toolbar">
            <div>
              <h2 class="section-heading">Employee records</h2>
              <p class="section-copy">Browse payroll-linked employee records and filter by department.</p>
            </div>

            <form class="filter-form" method="get" action="/employees">
              <label class="filter-label" for="department">Department</label>
              <select class="filter-select" id="department" name="department">
                <option value="">All departments</option>
                {{#each departments}}
                  <option value="{{this}}">{{this}}</option>
                {{/each}}
              </select>
              <button class="secondary-button" type="submit">Apply</button>
            </form>
          </div>

          <div class="table-wrap">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Employee</th>
                  <th>Department</th>
                  <th>Role</th>
                  <th>Pay grade</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {{#each employees}}
                  <tr>
                    <td>
                      <a class="table-link" href="/employees/{{this.employeeCode}}">{{this.fullName}}</a>
                      <span class="table-subtle">{{this.employeeCode}}</span>
                    </td>
                    <td>{{this.department}}</td>
                    <td>{{this.jobTitle}}</td>
                    <td>{{this.payGrade}}</td>
                    <td>{{this.employmentStatus}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
    <script>
      const select = document.getElementById('department');
      if (select) {
        select.value = '{{selectedDepartment}}';
      }
    </script>
  </body>
</html>
