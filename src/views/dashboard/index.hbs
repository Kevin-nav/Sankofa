<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <div class="dashboard-grid">
          <section class="metrics-grid">
            {{#each dashboardCards}}
              <article class="metric-card">
                <span class="metric-label">{{this.label}}</span>
                <strong class="metric-value">{{this.value}}</strong>
                <p class="metric-detail">{{this.detail}}</p>
              </article>
            {{/each}}
          </section>

          <section class="activity-card">
            <h2>Recent operational context</h2>
            <ul class="activity-list">
              {{#each activityItems}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </section>
        </div>
      </section>
    </main>
  </body>
</html>
