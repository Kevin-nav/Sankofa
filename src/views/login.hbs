<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sankofa Internal Access</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body class="login-body">
    <main class="login-shell">
      <section class="login-aside">
        <p class="login-eyebrow">Sankofa Payroll &amp; Compliance Services</p>
        <h1 class="login-title">Quarterly payroll operations, one trusted desk.</h1>
        <p class="login-summary">
          Internal access for payroll administration, compliance verification, and
          audit review. This demonstration environment uses seeded company records
          and role-based session access.
        </p>

        <div class="login-rail">
          <article class="rail-card">
            <strong>Payroll Administration</strong>
            <span>Batch oversight, employee records, and controlled payroll review.</span>
          </article>
          <article class="rail-card">
            <strong>Compliance Verification</strong>
            <span>Quarterly sign-off workflows, exceptions, and policy checks.</span>
          </article>
          <article class="rail-card">
            <strong>Audit Evidence</strong>
            <span>Read-only activity records, login history, and mock system events.</span>
          </article>
        </div>
      </section>

      <section class="login-panel">
        <span class="panel-badge">{{title}}</span>
        <h2>Secure internal sign in</h2>
        <p>Use one of the seeded demo accounts to access the internal platform.</p>

        {{#if error}}
          <div class="error-banner">{{error}}</div>
        {{/if}}

        <form class="auth-form" method="post" action="/login">
          <label class="field-label">
            Work email
            <input class="field-input" type="email" name="email" placeholder="name@sankofa.local" required />
          </label>
          <label class="field-label">
            Access phrase
            <input class="field-input" type="password" name="password" placeholder="demo-password" required />
          </label>
          <button class="primary-button" type="submit">Enter Internal Platform</button>
        </form>

        <div class="demo-accounts">
          <strong>Demo accounts:</strong><br />
          `anita@sankofa.local`, `felix@sankofa.local`, `akosua.audit@sankofa.local`<br />
          Shared password: `demo-password`
        </div>
      </section>
    </main>
  </body>
</html>
