<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <div class="detail-grid">
            <article class="detail-card">
              <span class="detail-kicker">Review Status</span>
              <h2>{{review.batch.quarter}} {{review.batch.year}}</h2>
              <div class="detail-stack">
                <div><strong>Status</strong><span>{{review.reviewStatus}}</span></div>
                <div><strong>Reviewer</strong><span>{{review.reviewer.name}}</span></div>
                <div><strong>Completed checks</strong><span>{{review.completedChecks}}</span></div>
                <div><strong>Approved at</strong><span>{{review.approvedAt}}</span></div>
                <div><strong>Comments</strong><span>{{review.comments}}</span></div>
              </div>
            </article>

            <article class="detail-card">
              <span class="detail-kicker">Batch Linkage</span>
              <h2>{{review.batch.batchCode}}</h2>
              <div class="detail-stack">
                <div><strong>Batch status</strong><span>{{review.batch.status}}</span></div>
                <div><strong>Total gross</strong><span>{{review.batch.totalGross}}</span></div>
                <div><strong>Total net</strong><span>{{review.batch.totalNet}}</span></div>
                <div><strong>Flag count</strong><span>{{review.flags.length}}</span></div>
              </div>
            </article>
          </div>

          <div class="table-wrap table-block">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Employee</th>
                  <th>Severity</th>
                  <th>Rule type</th>
                  <th>Resolution</th>
                  <th>Description</th>
                </tr>
              </thead>
              <tbody>
                {{#each review.flags}}
                  <tr>
                    <td>
                      <span class="table-link">{{this.payrollEntry.employee.fullName}}</span>
                      <span class="table-subtle">{{this.payrollEntry.employee.employeeCode}}</span>
                    </td>
                    <td>{{this.severity}}</td>
                    <td>{{this.ruleType}}</td>
                    <td>{{this.resolutionState}}</td>
                    <td>{{this.description}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
