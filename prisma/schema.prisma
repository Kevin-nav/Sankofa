generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PAYROLL_ADMIN
  COMPLIANCE_OFFICER
  AUDIT_ANALYST
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole
  department   String
  status       String
  lastLogin    DateTime?
  createdBatches PayrollBatch[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Employee {
  id                  Int      @id @default(autoincrement())
  employeeCode        String   @unique
  fullName            String
  department          String
  jobTitle            String
  payGrade            String
  taxIdentifier       String
  bankName            String
  maskedAccountNumber String
  employmentStatus    String
  payrollEntries      PayrollEntry[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PayrollBatch {
  id         Int            @id @default(autoincrement())
  batchCode  String         @unique
  quarter    String
  year       Int
  status     String
  submittedAt DateTime?
  totalGross Float
  totalNet   Float
  createdById Int
  createdBy  User           @relation(fields: [createdById], references: [id])
  entries    PayrollEntry[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model PayrollEntry {
  id          Int          @id @default(autoincrement())
  batchId     Int
  employeeId  Int
  baseSalary  Float
  allowances  Float
  deductions  Float
  tax         Float
  netPay      Float
  notes       String?
  isFlagged   Boolean      @default(false)
  batch       PayrollBatch @relation(fields: [batchId], references: [id])
  employee    Employee     @relation(fields: [employeeId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([batchId, employeeId])
}
