<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <div class="toolbar">
            <div>
              <h2 class="section-heading">Assigned review queue</h2>
              <p class="section-copy">Track sign-off status, completed checks, and unresolved compliance flags.</p>
            </div>
          </div>

          <div class="table-wrap">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Batch</th>
                  <th>Status</th>
                  <th>Reviewer</th>
                  <th>Completed checks</th>
                  <th>Open flags</th>
                </tr>
              </thead>
              <tbody>
                {{#each reviews}}
                  <tr>
                    <td>
                      <a class="table-link" href="/compliance/{{this.batch.batchCode}}">{{this.batch.quarter}} {{this.batch.year}}</a>
                      <span class="table-subtle">{{this.batch.batchCode}}</span>
                    </td>
                    <td>{{this.reviewStatus}}</td>
                    <td>{{this.reviewer.name}}</td>
                    <td>{{this.completedChecks}}</td>
                    <td>{{this._count.flags}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
