<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} | Sankofa Internal Platform</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <main class="app-shell">
      {{> sidebar}}
      <section class="workspace">
        {{> header}}

        <section class="content-card">
          <div class="toolbar">
            <div>
              <h2 class="section-heading">Quarterly payroll batches</h2>
              <p class="section-copy">Review batch state, ownership, totals, and employee counts.</p>
            </div>
          </div>

          <div class="table-wrap">
            <table class="directory-table">
              <thead>
                <tr>
                  <th>Batch</th>
                  <th>Status</th>
                  <th>Prepared by</th>
                  <th>Total gross</th>
                  <th>Total net</th>
                  <th>Entries</th>
                </tr>
              </thead>
              <tbody>
                {{#each batches}}
                  <tr>
                    <td>
                      <a class="table-link" href="/payroll/{{this.batchCode}}">{{this.quarter}} {{this.year}}</a>
                      <span class="table-subtle">{{this.batchCode}}</span>
                    </td>
                    <td>{{this.status}}</td>
                    <td>{{this.createdBy.name}}</td>
                    <td>{{this.totalGross}}</td>
                    <td>{{this.totalNet}}</td>
                    <td>{{this._count.entries}}</td>
                  </tr>
                {{else}}
                  <tr>
                    <td class="empty-cell" colspan="6">No payroll batches are currently available.</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
